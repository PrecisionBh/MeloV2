{
  "expo": {
    "name": "Melo",
    "slug": "Melo-MP",
    "version": "1.0.17",
    "orientation": "portrait",
    "scheme": "melomp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bhoffman4.MeloMP",
      "buildNumber": "18",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.bhoffman4.MeloMP",
      "versionCode": 18,
      "googleServicesFile": "./google-services.json",
      "permissions": ["com.android.vending.BILLING"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0F172A",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "@stripe/stripe-react-native",
        {}
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "stripePublishableKey": "pk_live_51Spqd6DaisGHVOvPbSPvngC4dais3IRv3SyLU2k9IJTh94dUTLCiGWy00tcYjZWI7547mToE6qWEp3nbhJx26Qnh00gURO9tMN",
      "router": {},
      "eas": {
        "projectId": "d3c5c61c-a428-41f5-b2cd-ce9bc35b2f3c"
      }
    },

    "owner": "bhoffman4"
  }
}